{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI-Pulse Daily News Bundle",
  "type": "object",
  "required": ["date", "generated_at", "generator_version", "sources_polled", "items"],
  "properties": {
    "date":             { "type": "string", "format": "date" },
    "generated_at":     { "type": "string", "format": "date-time" },
    "generator_version":{ "type": "string" },
    "sources_polled":   { "type": "array", "items": { "type": "string" } },
    "items": {
      "type": "array",
      "minItems": 1, "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "rank","id","title","url","source","source_type","published_at",
          "summary","why_it_matters","suggested_reel_angle",
          "suggested_long_angle","tags","related_registry_entries",
          "authority_score","virality_score","recency_hours"
        ],
        "properties": {
          "rank":                 { "type": "integer", "minimum": 1, "maximum": 5 },
          "id":                   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{3}$" },
          "title":                { "type": "string", "maxLength": 200 },
          "url":                  { "type": "string", "format": "uri" },
          "source":               { "type": "string" },
          "source_type":          { "type": "string", "enum": ["official_blog","news_aggregator","research","community"] },
          "published_at":         { "type": "string", "format": "date-time" },
          "summary":              { "type": "string", "maxLength": 500 },
          "why_it_matters":       { "type": "string", "maxLength": 800 },
          "suggested_reel_angle": { "type": "string", "maxLength": 200 },
          "suggested_long_angle": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 3 },
          "tags":                 { "type": "array", "items": { "type": "string" } },
          "related_registry_entries": { "type": "array", "items": { "type": "string" } },
          "authority_score":      { "type": "number", "minimum": 0, "maximum": 1 },
          "virality_score":       { "type": "number", "minimum": 0, "maximum": 1 },
          "recency_hours":        { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
